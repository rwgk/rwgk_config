#!/bin/bash
set -euo pipefail

# "make log timestamp"
# Appends timezone offset if not in PST/PDT timezone

if [[ $# -ne 0 ]]; then
    echo "Usage: $(basename "$0")" >&2
    exit 1
fi

tz_abbr="$(date +%Z 2>/dev/null || echo "")"

if [[ "$tz_abbr" == "PST" ]] || [[ "$tz_abbr" == "PDT" ]]; then
    date "+%Y-%m-%d+%H%M%S"
else
    date "+%Y-%m-%d+%H%M%S%z"
fi
