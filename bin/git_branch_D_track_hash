#!/bin/bash
set -euo pipefail

usage() {
    cat >&2 <<EOF
Usage: $(basename "$0") [--local-only | --rename-tracking | --archive-to-remote=<remote>] <branch> [<branch> ...]

Options:
  --local-only                 Delete only the local branch.
  --rename-tracking            Also archive the tracked remote branch, even
                               when it is not safe to do so by default.
  --archive-to-remote=<remote> If the tracked branch is not on your fork,
                               archive it to your fork remote, then delete the
                               tracked remote branch.

Default behavior:
  The tracked remote branch is archived only when this script can identify the
  remote as your authenticated GitHub fork and confirm that there is no open PR.
  Upstream and other non-fork remotes require --local-only, --rename-tracking,
  or --archive-to-remote=<remote>.
  A tracked remote branch on someone else's GitHub fork is left unchanged.
EOF
}

get_remote_upstream_info() {
    local branch="$1"
    local remote remote_ref

    remote=$(git for-each-ref --format='%(upstream:remotename)' "refs/heads/$branch")
    remote_ref=$(git for-each-ref --format='%(upstream:remoteref)' "refs/heads/$branch")

    if [[ -z "$remote" ]] || [[ -z "$remote_ref" ]] || [[ "$remote" == "." ]]; then
        return 1
    fi
    if [[ "$remote_ref" != refs/heads/* ]]; then
        return 1
    fi

    printf '%s\t%s\n' "$remote" "${remote_ref#refs/heads/}"
}

get_remote_branch_sha() {
    local remote="$1"
    local remote_branch="$2"
    local ls_remote_output

    if ! ls_remote_output=$(git ls-remote --heads "$remote" "refs/heads/$remote_branch"); then
        echo "Error: failed to query remote branch '$remote/$remote_branch'." >&2
        return 1
    fi

    if [[ -n "$ls_remote_output" ]]; then
        printf '%s\n' "${ls_remote_output%%$'\t'*}"
    fi
}

get_github_remote_repo_info() {
    local remote="$1"
    local remote_url gh_output viewer_login repo_url repo_host repo_name is_fork repo_owner

    if ! command -v gh >/dev/null 2>&1; then
        echo "Error: 'gh' is not installed or not on PATH." >&2
        return 1
    fi

    if ! remote_url=$(git remote get-url --push "$remote" 2>&1); then
        printf '%s\n' "$remote_url" >&2
        return 1
    fi

    if ! gh_output=$(gh repo view "$remote_url" \
        --json url,nameWithOwner,isFork,owner \
        --jq '[.url, .nameWithOwner, .isFork, .owner.login] | @tsv' 2>&1); then
        printf '%s\n' "$gh_output" >&2
        return 1
    fi

    IFS=$'\t' read -r repo_url repo_name is_fork repo_owner <<<"$gh_output"
    repo_host="${repo_url#https://}"
    repo_host="${repo_host%%/*}"
    if [[ -z "$repo_host" || "$repo_host" == "$repo_url" ]]; then
        printf "Error: cannot determine GitHub host from repository URL '%s'.\n" "$repo_url" >&2
        return 1
    fi

    if ! viewer_login=$(gh api --hostname "$repo_host" user --jq .login 2>&1); then
        printf '%s\n' "$viewer_login" >&2
        return 1
    fi

    printf '%s\t%s\t%s\t%s\t%s\n' "$repo_name" "$is_fork" "$repo_owner" "$viewer_login" "$repo_host"
}

query_pr_info_for_remote_branch() {
    local head_owner="$1"
    local remote_branch="$2"
    local pr_state_filter="${3:-all}"
    local github_host="${4:-}"
    local gh_output
    local -a gh_args=(
        search prs
        --head "$head_owner:$remote_branch"
        --limit 1000
        --json number,state,url
        --jq '.[0] | if . then "\(.number)\t\(.state)\t\(.url)" else empty end'
    )

    if [[ "$pr_state_filter" != "all" ]]; then
        gh_args+=(--state "$pr_state_filter")
    fi

    if ! command -v gh >/dev/null 2>&1; then
        echo "Error: 'gh' is not installed or not on PATH." >&2
        return 1
    fi

    if [[ -n "$github_host" ]]; then
        gh_output=$(GH_HOST="$github_host" gh "${gh_args[@]}" 2>&1) || {
            printf '%s\n' "$gh_output" >&2
            return 1
        }
    elif ! gh_output=$(gh "${gh_args[@]}" 2>&1); then
        printf '%s\n' "$gh_output" >&2
        return 1
    fi

    printf '%s\n' "$gh_output"
}

print_pr_state_unknown_error() {
    local remote="$1"
    local remote_branch="$2"
    local details="${3:-}"

    echo "Error: cannot determine PR state for remote branch '$remote/$remote_branch'." >&2
    if [[ -n "$details" ]]; then
        printf '%s\n' "$details" >&2
    fi
    echo "Deleting or renaming the remote branch would be unsafe until PR state is known." >&2
    echo "Please close the PR first, then try again." >&2
    echo "Or use the --local-only option." >&2
}

print_explicit_remote_choice_required_error() {
    local remote="$1"
    local remote_branch="$2"
    local reason="$3"
    local details="${4:-}"

    printf "Error: tracked remote branch '%s/%s' is not safe to rename by default.\n" "$remote" "$remote_branch" >&2
    printf '%s\n' "$reason" >&2
    if [[ -n "$details" ]]; then
        printf '%s\n' "$details" >&2
    fi
    echo "Use --local-only to delete only the local branch." >&2
    echo "Use --rename-tracking to also archive the tracked remote branch." >&2
    echo "Use --archive-to-remote=<remote> to archive to your fork before deleting the tracked branch." >&2
}

print_open_pr_error() {
    local remote="$1"
    local remote_branch="$2"
    local pr_number="$3"
    local pr_url="$4"

    printf "Error: remote branch '%s/%s' still has open PR #%s:\n" "$remote" "$remote_branch" "$pr_number" >&2
    printf "  %s\n" "$pr_url" >&2
    echo "Deleting or renaming the remote branch would likely close the PR." >&2
    echo "Please close the PR first, then try again." >&2
    echo "Or use the --local-only option." >&2
}

build_archive_remote_branch_name() {
    local remote_branch="$1"
    local pr_number="$2"
    local timestamp

    timestamp=$(mlt)
    if [[ -n "$pr_number" ]]; then
        printf 'archive/%s_pr%s_%s\n' "$timestamp" "$pr_number" "$remote_branch"
    else
        printf 'archive/%s_%s\n' "$timestamp" "$remote_branch"
    fi
}

plan_remote_branch_archive() {
    local remote="$1"
    local remote_branch="$2"
    local remote_sha="$3"
    local pr_head_owner="${4:-}"
    local pr_lookup_host="${5:-}"
    local require_pr_check="${6:-1}"
    local archive_remote="${7:-$remote}"
    local open_pr_info pr_info
    local pr_number="" pr_state="" pr_url="" archive_branch archive_sha

    if [[ -n "$pr_head_owner" ]]; then
        if ! open_pr_info=$(query_pr_info_for_remote_branch "$pr_head_owner" "$remote_branch" open "$pr_lookup_host" 2>&1); then
            if [[ "$require_pr_check" -eq 1 ]]; then
                print_pr_state_unknown_error "$remote" "$remote_branch" "$open_pr_info"
                return 1
            fi
            printf "Warning: could not determine PR state for '%s/%s'; proceeding because remote archive/delete was explicitly requested.\n" "$remote" "$remote_branch" >&2
            printf '%s\n' "$open_pr_info" >&2
        elif [[ -n "$open_pr_info" ]]; then
            IFS=$'\t' read -r pr_number pr_state pr_url <<<"$open_pr_info"
            print_open_pr_error "$remote" "$remote_branch" "$pr_number" "$pr_url"
            return 1
        fi
    else
        printf "Warning: PR state was not checked for '%s/%s'; proceeding because remote archive/delete was explicitly requested.\n" "$remote" "$remote_branch" >&2
    fi

    if [[ -n "$pr_head_owner" ]] && pr_info=$(query_pr_info_for_remote_branch "$pr_head_owner" "$remote_branch" all "$pr_lookup_host" 2>/dev/null) && [[ -n "$pr_info" ]]; then
        IFS=$'\t' read -r pr_number pr_state pr_url <<<"$pr_info"
    fi

    archive_branch=$(build_archive_remote_branch_name "$remote_branch" "$pr_number")

    if ! archive_sha=$(get_remote_branch_sha "$archive_remote" "$archive_branch"); then
        return 1
    fi
    if [[ -n "$archive_sha" ]]; then
        echo "Error: archive branch already exists on remote: '$archive_remote/$archive_branch'." >&2
        return 1
    fi

    printf '%s\t%s\t%s\t%s\t%s\n' "$remote" "$remote_branch" "$remote_sha" "$archive_branch" "$archive_remote"
}

get_owned_fork_remote_info() {
    local remote="$1"
    local repo_info repo_name is_fork repo_owner viewer_login repo_host

    if ! repo_info=$(get_github_remote_repo_info "$remote" 2>&1); then
        printf "Error: cannot determine whether archive remote '%s' is your GitHub fork.\n" "$remote" >&2
        printf '%s\n' "$repo_info" >&2
        return 1
    fi

    IFS=$'\t' read -r repo_name is_fork repo_owner viewer_login repo_host <<<"$repo_info"
    if [[ "$is_fork" != "true" || "$repo_owner" != "$viewer_login" ]]; then
        printf "Error: archive remote '%s' points to '%s', which is not your authenticated GitHub fork.\n" "$remote" "$repo_name" >&2
        printf "Authenticated GitHub user: '%s'; repository owner: '%s'; is fork: '%s'.\n" "$viewer_login" "$repo_owner" "$is_fork" >&2
        return 1
    fi

    printf '%s\t%s\t%s\t%s\t%s\n' "$repo_name" "$is_fork" "$repo_owner" "$viewer_login" "$repo_host"
}

plan_remote_tracking_archive() {
    local branch="$1"
    local archive_mode="$2"
    local upstream_info remote remote_branch remote_sha repo_info repo_name is_fork repo_owner viewer_login repo_host
    local archive_to_remote="" archive_repo_info archive_repo_name archive_is_fork archive_repo_owner archive_viewer_login archive_repo_host
    local pr_head_owner="" pr_lookup_host="" require_pr_check=1

    if ! upstream_info=$(get_remote_upstream_info "$branch"); then
        return 0
    fi

    IFS=$'\t' read -r remote remote_branch <<<"$upstream_info"

    if ! remote_sha=$(get_remote_branch_sha "$remote" "$remote_branch"); then
        return 1
    fi
    if [[ -z "$remote_sha" ]]; then
        return 0
    fi

    case "$archive_mode" in
    auto)
        if ! repo_info=$(get_github_remote_repo_info "$remote" 2>&1); then
            print_explicit_remote_choice_required_error \
                "$remote" \
                "$remote_branch" \
                "Cannot determine whether '$remote' is your GitHub fork." \
                "$repo_info"
            return 1
        fi

        IFS=$'\t' read -r repo_name is_fork repo_owner viewer_login repo_host <<<"$repo_info"
        if [[ "$is_fork" == "true" && "$repo_owner" == "$viewer_login" ]]; then
            pr_head_owner="$repo_owner"
            pr_lookup_host="$repo_host"
        elif [[ "$is_fork" == "true" ]]; then
            printf "INFO: tracked remote branch '%s/%s' is on fork '%s', owned by '%s'; leaving the remote branch unchanged.\n" "$remote" "$remote_branch" "$repo_name" "$repo_owner" >&2
            return 0
        else
            print_explicit_remote_choice_required_error \
                "$remote" \
                "$remote_branch" \
                "Remote repository '$repo_name' is not a fork owned by '$viewer_login'."
            return 1
        fi
        ;;
    archive-to-remote:*)
        archive_to_remote="${archive_mode#archive-to-remote:}"
        if [[ -z "$archive_to_remote" ]]; then
            echo "Error: --archive-to-remote requires a remote name." >&2
            return 1
        fi
        if ! repo_info=$(get_github_remote_repo_info "$remote" 2>&1); then
            print_explicit_remote_choice_required_error \
                "$remote" \
                "$remote_branch" \
                "Cannot determine whether tracked remote '$remote' is your GitHub fork." \
                "$repo_info"
            return 1
        fi

        IFS=$'\t' read -r repo_name is_fork repo_owner viewer_login repo_host <<<"$repo_info"
        pr_head_owner="$repo_owner"
        pr_lookup_host="$repo_host"
        if [[ "$is_fork" == "true" && "$repo_owner" == "$viewer_login" ]]; then
            printf "INFO: tracked remote branch '%s/%s' is already on your fork; archiving on the tracked remote.\n" "$remote" "$remote_branch" >&2
        else
            if ! archive_repo_info=$(get_owned_fork_remote_info "$archive_to_remote"); then
                return 1
            fi
            IFS=$'\t' read -r archive_repo_name archive_is_fork archive_repo_owner archive_viewer_login archive_repo_host <<<"$archive_repo_info"
            printf "INFO: tracked remote branch '%s/%s' will be archived to '%s' before deletion from '%s'.\n" "$remote" "$remote_branch" "$archive_to_remote" "$remote" >&2
        fi
        ;;
    rename-tracking)
        if repo_info=$(get_github_remote_repo_info "$remote" 2>/dev/null); then
            IFS=$'\t' read -r repo_name is_fork repo_owner viewer_login repo_host <<<"$repo_info"
            pr_head_owner="$repo_owner"
            pr_lookup_host="$repo_host"
        else
            require_pr_check=0
        fi
        ;;
    *)
        echo "ASSERTION FAILURE: unknown archive mode '$archive_mode'" >&2
        return 1
        ;;
    esac

    if [[ -n "$archive_to_remote" && ! ( "$is_fork" == "true" && "$repo_owner" == "$viewer_login" ) ]]; then
        plan_remote_branch_archive "$remote" "$remote_branch" "$remote_sha" "$pr_head_owner" "$pr_lookup_host" "$require_pr_check" "$archive_to_remote"
    else
        plan_remote_branch_archive "$remote" "$remote_branch" "$remote_sha" "$pr_head_owner" "$pr_lookup_host" "$require_pr_check"
    fi
}

rename_remote_upstream_branch() {
    local remote="$1"
    local remote_branch="$2"
    local remote_sha="$3"
    local archive_branch="$4"
    local archive_remote="${5:-$remote}"
    local push_output

    if [[ "$archive_remote" == "$remote" ]]; then
        if ! push_output=$(git push --atomic "$remote" "$remote_sha:refs/heads/$archive_branch" ":refs/heads/$remote_branch" 2>&1); then
            echo "Error: failed to rename remote branch '$remote/$remote_branch' to '$remote/$archive_branch'." >&2
            printf '%s\n' "$push_output" >&2
            return 1
        fi

        printf 'INFO: remote branch %s/%s renamed to %s/%s\n' "$remote" "$remote_branch" "$remote" "$archive_branch"
        return 0
    fi

    if ! push_output=$(git push "$archive_remote" "$remote_sha:refs/heads/$archive_branch" 2>&1); then
        echo "Error: failed to archive remote branch '$remote/$remote_branch' to '$archive_remote/$archive_branch'." >&2
        printf '%s\n' "$push_output" >&2
        return 1
    fi

    if ! push_output=$(git push "$remote" ":refs/heads/$remote_branch" 2>&1); then
        echo "Error: archived remote branch to '$archive_remote/$archive_branch', but failed to delete '$remote/$remote_branch'." >&2
        printf '%s\n' "$push_output" >&2
        return 1
    fi

    printf 'INFO: remote branch %s/%s archived to %s/%s and deleted from %s\n' "$remote" "$remote_branch" "$archive_remote" "$archive_branch" "$remote"
}

print_backup_failure_error() {
    local branch="$1"
    local destination="$2"
    local details="${3:-}"
    local remote_rename_done="$4"

    printf "Error: failed to back up branch tip for '%s' to '%s'.\n" "$branch" "$destination" >&2
    if [[ -n "$details" ]]; then
        printf '%s\n' "$details" >&2
    fi
    if [[ "$remote_rename_done" -eq 1 ]]; then
        echo "The remote archive rename already succeeded, but the local branch has not been deleted." >&2
        echo "Please resolve the backup problem and rerun the command; rerunning is safe." >&2
    else
        echo "The local branch has not been deleted." >&2
        echo "Please resolve the backup problem and try again." >&2
    fi
}

back_up_branch_tip() {
    local branch="$1"
    local commit="$2"
    local remote_rename_done="$3"
    local repo timestamp safe_repo safe_branch infofile backup_output

    repo=$(basename "$(git rev-parse --show-toplevel)")
    timestamp=$(date +%Y-%m-%d+%H%M%S)
    safe_repo="${repo//[^A-Za-z0-9._@-]/_}"
    safe_branch="${branch//[^A-Za-z0-9._@-]/_}"
    infofile="/tmp/${safe_repo}_${safe_branch}_${timestamp}.txt"

    if ! backup_output=$({
        echo "Current host: '$(hostfqdn)'"
        echo "Current working directory: '$(pwd)'"
        echo "Repository: '$repo'"
        echo "Archiving \`git show --stat --summary\` output before \`git branch -D \"$branch\"\`"
        echo
        git show --stat --summary "$commit"
    } 2>&1 >"$infofile"); then
        print_backup_failure_error "$branch" "$infofile" "$backup_output" "$remote_rename_done"
        return 1
    fi

    if [[ -n "${MY_GIT_BACKTRACKING_INFO_LOCAL:-}" ]]; then
        if ! backup_output=$(cp -p "$infofile" "$MY_GIT_BACKTRACKING_INFO_LOCAL/" 2>&1); then
            print_backup_failure_error "$branch" "$MY_GIT_BACKTRACKING_INFO_LOCAL/" "$backup_output" "$remote_rename_done"
            return 1
        fi
        echo "Backed up branch tip to: '$MY_GIT_BACKTRACKING_INFO_LOCAL/$(basename "$infofile")'"
    elif [[ -n "${MY_GIT_BACKTRACKING_INFO_REMOTE:-}" ]]; then
        if ! backup_output=$(scp -p "$infofile" "$MY_GIT_BACKTRACKING_INFO_REMOTE" 2>&1); then
            print_backup_failure_error "$branch" "$MY_GIT_BACKTRACKING_INFO_REMOTE" "$backup_output" "$remote_rename_done"
            return 1
        fi
        echo "Backed up branch tip to: '$MY_GIT_BACKTRACKING_INFO_REMOTE'"
    fi
}

archive_branch_tip_and_delete() (
    set -euo pipefail

    if [[ $# -ne 2 ]]; then
        echo "ASSERTION FAILURE: archive_branch_tip_and_delete requires exactly 2 arguments (got $#)" >&2
        return 1
    fi

    local archive_mode="$1"
    local branch="$2"
    local current_branch commit
    local remote_rename_done=0
    local remote_archive_plan remote remote_branch remote_sha archive_branch archive_remote

    if [[ -z "${MY_GIT_BACKTRACKING_INFO_LOCAL:-}" && -z "${MY_GIT_BACKTRACKING_INFO_REMOTE:-}" ]]; then
        echo "Error: Neither MY_GIT_BACKTRACKING_INFO_LOCAL nor MY_GIT_BACKTRACKING_INFO_REMOTE is set." >&2
        return 1
    fi

    if ! git show-ref --verify --quiet "refs/heads/$branch"; then
        echo "Error: branch '$branch' not found." >&2
        return 1
    fi

    current_branch=$(git symbolic-ref --short HEAD 2>/dev/null) || true
    if [[ "$branch" == "$current_branch" ]]; then
        echo "Error: '$branch' is the current branch. Switch to another branch first." >&2
        return 1
    fi

    if [[ "$archive_mode" != "local-only" ]]; then
        remote_archive_plan=$(plan_remote_tracking_archive "$branch" "$archive_mode") || return
    fi

    commit=$(git rev-parse "$branch")

    if [[ -n "${remote_archive_plan:-}" ]]; then
        IFS=$'\t' read -r remote remote_branch remote_sha archive_branch archive_remote <<<"$remote_archive_plan"
        rename_remote_upstream_branch "$remote" "$remote_branch" "$remote_sha" "$archive_branch" "${archive_remote:-$remote}" || return
        remote_rename_done=1
    fi

    back_up_branch_tip "$branch" "$commit" "$remote_rename_done" || return

    git branch -D "$branch"
)

main() {
    local archive_mode=auto
    local arg
    local -a branches=()

    if [[ $# -eq 0 ]]; then
        usage
        exit 1
    fi

    while [[ $# -gt 0 ]]; do
        arg="$1"
        shift
        case "$arg" in
        --local-only)
            if [[ "$archive_mode" != "auto" ]]; then
                echo "Error: --local-only, --rename-tracking, and --archive-to-remote are mutually exclusive." >&2
                usage
                exit 1
            fi
            archive_mode=local-only
            ;;
        --rename-tracking)
            if [[ "$archive_mode" != "auto" ]]; then
                echo "Error: --local-only, --rename-tracking, and --archive-to-remote are mutually exclusive." >&2
                usage
                exit 1
            fi
            archive_mode=rename-tracking
            ;;
        --archive-to-remote=*)
            if [[ "$archive_mode" != "auto" ]]; then
                echo "Error: --local-only, --rename-tracking, and --archive-to-remote are mutually exclusive." >&2
                usage
                exit 1
            fi
            archive_mode="archive-to-remote:${arg#--archive-to-remote=}"
            ;;
        --archive-to-remote)
            echo "Error: --archive-to-remote requires '=REMOTE', for example --archive-to-remote=origin." >&2
            usage
            exit 1
            ;;
        --help | -h)
            usage
            exit 0
            ;;
        --)
            branches+=("$@")
            break
            ;;
        -*)
            echo "Error: unknown option '$arg'." >&2
            usage
            exit 1
            ;;
        *)
            branches+=("$arg")
            ;;
        esac
    done

    if [[ ${#branches[@]} -eq 0 ]]; then
        usage
        exit 1
    fi

    for arg in "${branches[@]}"; do
        archive_branch_tip_and_delete "$archive_mode" "$arg"
    done
}

main "$@"
