#!/bin/bash
set -euo pipefail

usage() {
    echo "Usage: $(basename "$0") [--local-only] <branch> [<branch> ...]" >&2
}

get_remote_upstream_info() {
    local branch="$1"
    local remote remote_ref

    remote=$(git for-each-ref --format='%(upstream:remotename)' "refs/heads/$branch")
    remote_ref=$(git for-each-ref --format='%(upstream:remoteref)' "refs/heads/$branch")

    if [[ -z "$remote" ]] || [[ -z "$remote_ref" ]] || [[ "$remote" == "." ]]; then
        return 1
    fi
    if [[ "$remote_ref" != refs/heads/* ]]; then
        return 1
    fi

    printf '%s\t%s\n' "$remote" "${remote_ref#refs/heads/}"
}

get_remote_branch_sha() {
    local remote="$1"
    local remote_branch="$2"
    local ls_remote_output

    if ! ls_remote_output=$(git ls-remote --heads "$remote" "refs/heads/$remote_branch"); then
        echo "Error: failed to query remote branch '$remote/$remote_branch'." >&2
        return 1
    fi

    if [[ -n "$ls_remote_output" ]]; then
        printf '%s\n' "${ls_remote_output%%$'\t'*}"
    fi
}

query_pr_info_for_remote_branch() {
    local remote_branch="$1"
    local pr_state_filter="${2:-all}"
    local gh_output

    if ! command -v gh >/dev/null 2>&1; then
        echo "Error: 'gh' is not installed or not on PATH." >&2
        return 1
    fi

    if ! gh_output=$(gh pr list \
        --head "$remote_branch" \
        --state "$pr_state_filter" \
        --limit 1000 \
        --json number,state,url \
        --jq '.[0] | if . then "\(.number)\t\(.state)\t\(.url)" else empty end' 2>&1); then
        printf '%s\n' "$gh_output" >&2
        return 1
    fi

    printf '%s\n' "$gh_output"
}

print_pr_state_unknown_error() {
    local remote="$1"
    local remote_branch="$2"
    local details="${3:-}"

    echo "Error: cannot determine PR state for upstream branch '$remote/$remote_branch'." >&2
    if [[ -n "$details" ]]; then
        printf '%s\n' "$details" >&2
    fi
    echo "Renaming the remote branch would be unsafe until PR state is known." >&2
    echo "Please close the PR first, then try again." >&2
    echo "Or use the --local-only option." >&2
}

build_archive_remote_branch_name() {
    local remote_branch="$1"
    local pr_number="$2"
    local timestamp

    timestamp=$(mlt)
    if [[ -n "$pr_number" ]]; then
        printf 'archive/%s_pr%s_%s\n' "$timestamp" "$pr_number" "$remote_branch"
    else
        printf 'archive/%s_%s\n' "$timestamp" "$remote_branch"
    fi
}

plan_remote_upstream_archive() {
    local branch="$1"
    local upstream_info remote remote_branch remote_sha open_pr_info pr_info
    local pr_number="" pr_state="" pr_url="" archive_branch archive_sha

    if ! upstream_info=$(get_remote_upstream_info "$branch"); then
        return 0
    fi

    IFS=$'\t' read -r remote remote_branch <<<"$upstream_info"

    if ! remote_sha=$(get_remote_branch_sha "$remote" "$remote_branch"); then
        return 1
    fi
    if [[ -z "$remote_sha" ]]; then
        return 0
    fi

    if ! open_pr_info=$(query_pr_info_for_remote_branch "$remote_branch" open 2>&1); then
        print_pr_state_unknown_error "$remote" "$remote_branch" "$open_pr_info"
        return 1
    fi
    if [[ -n "$open_pr_info" ]]; then
        IFS=$'\t' read -r pr_number pr_state pr_url <<<"$open_pr_info"
        printf "Error: upstream branch '%s/%s' still has open PR #%s:\n" "$remote" "$remote_branch" "$pr_number" >&2
        printf "  %s\n" "$pr_url" >&2
        echo "Renaming the remote branch would likely close the PR." >&2
        echo "Please close the PR first, then try again." >&2
        echo "Or use the --local-only option." >&2
        return 1
    fi

    if pr_info=$(query_pr_info_for_remote_branch "$remote_branch" all 2>/dev/null) && [[ -n "$pr_info" ]]; then
        IFS=$'\t' read -r pr_number pr_state pr_url <<<"$pr_info"
    fi

    archive_branch=$(build_archive_remote_branch_name "$remote_branch" "$pr_number")

    if ! archive_sha=$(get_remote_branch_sha "$remote" "$archive_branch"); then
        return 1
    fi
    if [[ -n "$archive_sha" ]]; then
        echo "Error: archive branch already exists on remote: '$remote/$archive_branch'." >&2
        return 1
    fi

    printf '%s\t%s\t%s\t%s\n' "$remote" "$remote_branch" "$remote_sha" "$archive_branch"
}

rename_remote_upstream_branch() {
    local remote="$1"
    local remote_branch="$2"
    local remote_sha="$3"
    local archive_branch="$4"
    local push_output

    if ! push_output=$(git push --atomic "$remote" "$remote_sha:refs/heads/$archive_branch" ":refs/heads/$remote_branch" 2>&1); then
        echo "Error: failed to rename upstream branch '$remote/$remote_branch' to '$remote/$archive_branch'." >&2
        printf '%s\n' "$push_output" >&2
        return 1
    fi

    printf 'INFO: upstream branch %s/%s renamed to %s/%s\n' "$remote" "$remote_branch" "$remote" "$archive_branch"
}

print_backup_failure_error() {
    local branch="$1"
    local destination="$2"
    local details="${3:-}"
    local remote_rename_done="$4"

    printf "Error: failed to back up branch tip for '%s' to '%s'.\n" "$branch" "$destination" >&2
    if [[ -n "$details" ]]; then
        printf '%s\n' "$details" >&2
    fi
    if [[ "$remote_rename_done" -eq 1 ]]; then
        echo "The upstream archive rename already succeeded, but the local branch has not been deleted." >&2
        echo "Please resolve the backup problem and rerun the command; rerunning is safe." >&2
    else
        echo "The local branch has not been deleted." >&2
        echo "Please resolve the backup problem and try again." >&2
    fi
}

back_up_branch_tip() {
    local branch="$1"
    local commit="$2"
    local remote_rename_done="$3"
    local repo timestamp safe_repo safe_branch infofile backup_output

    repo=$(basename "$(git rev-parse --show-toplevel)")
    timestamp=$(date +%Y-%m-%d+%H%M%S)
    safe_repo="${repo//[^A-Za-z0-9._@-]/_}"
    safe_branch="${branch//[^A-Za-z0-9._@-]/_}"
    infofile="/tmp/${safe_repo}_${safe_branch}_${timestamp}.txt"

    if ! backup_output=$({
        echo "Current host: '$(hostfqdn)'"
        echo "Current working directory: '$(pwd)'"
        echo "Repository: '$repo'"
        echo "Archiving \`git show --stat --summary\` output before \`git branch -D \"$branch\"\`"
        echo
        git show --stat --summary "$commit"
    } 2>&1 >"$infofile"); then
        print_backup_failure_error "$branch" "$infofile" "$backup_output" "$remote_rename_done"
        return 1
    fi

    if [[ -n "${MY_GIT_BACKTRACKING_INFO_LOCAL:-}" ]]; then
        if ! backup_output=$(cp -p "$infofile" "$MY_GIT_BACKTRACKING_INFO_LOCAL/" 2>&1); then
            print_backup_failure_error "$branch" "$MY_GIT_BACKTRACKING_INFO_LOCAL/" "$backup_output" "$remote_rename_done"
            return 1
        fi
        echo "Backed up branch tip to: '$MY_GIT_BACKTRACKING_INFO_LOCAL/$(basename "$infofile")'"
    elif [[ -n "${MY_GIT_BACKTRACKING_INFO_REMOTE:-}" ]]; then
        if ! backup_output=$(scp -p "$infofile" "$MY_GIT_BACKTRACKING_INFO_REMOTE" 2>&1); then
            print_backup_failure_error "$branch" "$MY_GIT_BACKTRACKING_INFO_REMOTE" "$backup_output" "$remote_rename_done"
            return 1
        fi
        echo "Backed up branch tip to: '$MY_GIT_BACKTRACKING_INFO_REMOTE'"
    fi
}

archive_branch_tip_and_delete() (
    set -euo pipefail

    if [[ $# -ne 2 ]]; then
        echo "ASSERTION FAILURE: archive_branch_tip_and_delete requires exactly 2 arguments (got $#)" >&2
        return 1
    fi

    local local_only="$1"
    local branch="$2"
    local current_branch commit
    local remote_rename_done=0
    local remote_archive_plan remote remote_branch remote_sha archive_branch

    if [[ -z "${MY_GIT_BACKTRACKING_INFO_LOCAL:-}" && -z "${MY_GIT_BACKTRACKING_INFO_REMOTE:-}" ]]; then
        echo "Error: Neither MY_GIT_BACKTRACKING_INFO_LOCAL nor MY_GIT_BACKTRACKING_INFO_REMOTE is set." >&2
        return 1
    fi

    if ! git show-ref --verify --quiet "refs/heads/$branch"; then
        echo "Error: branch '$branch' not found." >&2
        return 1
    fi

    current_branch=$(git symbolic-ref --short HEAD 2>/dev/null) || true
    if [[ "$branch" == "$current_branch" ]]; then
        echo "Error: '$branch' is the current branch. Switch to another branch first." >&2
        return 1
    fi

    if [[ "$local_only" -eq 0 ]]; then
        remote_archive_plan=$(plan_remote_upstream_archive "$branch") || return
    fi

    commit=$(git rev-parse "$branch")

    if [[ -n "${remote_archive_plan:-}" ]]; then
        IFS=$'\t' read -r remote remote_branch remote_sha archive_branch <<<"$remote_archive_plan"
        rename_remote_upstream_branch "$remote" "$remote_branch" "$remote_sha" "$archive_branch" || return
        remote_rename_done=1
    fi

    back_up_branch_tip "$branch" "$commit" "$remote_rename_done" || return

    git branch -D "$branch"
)

main() {
    local local_only=0
    local arg
    local -a branches=()

    if [[ $# -eq 0 ]]; then
        usage
        exit 1
    fi

    while [[ $# -gt 0 ]]; do
        arg="$1"
        shift
        case "$arg" in
        --local-only)
            local_only=1
            ;;
        --help | -h)
            usage
            exit 0
            ;;
        --)
            branches+=("$@")
            break
            ;;
        -*)
            echo "Error: unknown option '$arg'." >&2
            usage
            exit 1
            ;;
        *)
            branches+=("$arg")
            ;;
        esac
    done

    if [[ ${#branches[@]} -eq 0 ]]; then
        usage
        exit 1
    fi

    for arg in "${branches[@]}"; do
        archive_branch_tip_and_delete "$local_only" "$arg"
    done
}

main "$@"
